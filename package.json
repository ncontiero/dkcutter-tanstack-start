{
  "name": "dkcutter-tanstack-start",
  "type": "module",
  "private": true,
  "packageManager": "bun@1.3.14",
  "description": "DKCutter Tanstack Start is a robust template for quickly scaffolding production-ready Tanstack Start applications with modern tooling.",
  "author": "Nicolas Contiero <https://github.com/ncontiero>",
  "license": "MIT",
  "scripts": {
    "generate": "dkcutter .",
    "lint": "bun --bun eslint . -c eslint.config.js",
    "lint:fix": "bun run lint --fix",
    "typecheck": "bun --bun tsc --noEmit",
    "check": "bun run lint && bun run typecheck",
    "test": "vitest run",
    "test:typecheck": "RUN_TYPE_CHECK=true bun run test",
    "test:strict-eslint": "GET_WARNINGS=true bun run test",
    "pre-commit": "lint-staged -c ./package.json",
    "prepare": "husky"
  },
  "devDependencies": {
    "@clack/prompts": "1.7.0",
    "@commitlint/cli": "21.2.1",
    "@commitlint/config-conventional": "21.2.0",
    "@ncontiero/eslint-config": "8.3.3",
    "@tailwindcss/typography": "0.5.20",
    "@tanstack/eslint-plugin-query": "5.101.2",
    "@types/bun": "1.3.14",
    "ansis": "4.3.1",
    "dkcutter": "6.2.0",
    "eslint": "10.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "lint-staged": {
    "*": "bun run lint:fix"
  }
}
