# When adding additional environment variables, the schema in "./src/env.ts"
# should be updated accordingly.
{%- if dkcutter.usePrisma %}

# Database URL for PostgreSQL
DATABASE_URL="postgresql://postgres:postgresw@localhost:5432/postgres"
{%- endif %}
{%- if dkcutter.useSentry %}

# Sentry
VITE_SENTRY_DSN="YOUR_SENTRY_DSN"
VITE_SENTRY_ORG="YOUR_SENTRY_ORG"
VITE_SENTRY_PROJECT="YOUR_SENTRY_PROJECT"
SENTRY_AUTH_TOKEN="YOUR_SENTRY_AUTH_TOKEN"
{%- endif %}
{%- if dkcutter.authProvider == "clerk" %}

# Clerk Keys
VITE_CLERK_PUBLISHABLE_KEY="YOUR_CLERK_PUBLISHABLE_KEY"
CLERK_SECRET_KEY="YOUR_CLERK_SECRET_KEY"
{%- elif dkcutter.authProvider == "betterAuth" %}

# Better Auth
BETTER_AUTH_SECRET="!!!SET BETTER_AUTH_SECRET!!!"
BETTER_AUTH_URL="http://localhost:3000"
{%- endif %}
