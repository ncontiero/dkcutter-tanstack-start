{
  "name": "{{dkcutter.projectSlug}}",
  "type": "module",
  "version": "{{dkcutter.projectVersion}}",
  "private": true,
  "packageManager": "",
  "description": "{{dkcutter.description}}",
  "author": "{{dkcutter.authorName}}",
  "license": "MIT",
  "scripts": {
    "dev": "vite dev --port 3000",
    "generate-routes": "tsr generate",
    "build": "vite build",
    "preview": "vite preview",
    "db:init": "bunx --bun create-db@latest",
    "db:generate": "dotenv -e .env.local -- prisma generate",
    "db:push": "dotenv -e .env.local -- prisma db push",
    "db:migrate": "dotenv -e .env.local -- prisma migrate dev",
    "db:studio": "dotenv -e .env.local -- prisma studio",
    "db:seed": "dotenv -e .env.local -- prisma db seed"
  },
  "dependencies": {
    "@clerk/clerk-react": "5.61.3",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@t3-oss/env-core": "0.13.11",
    "@tailwindcss/vite": "4.3.0",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.25",
    "@tanstack/router-plugin": "1.168.18",
    "better-auth": "1.6.15",
    "lucide-react": "1.17.0",
    "nitro": "3.0.260603-beta",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwindcss": "4.3.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/typography": "0.5.20",
    "@tanstack/devtools-vite": "0.7.0",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-query-devtools": "5.101.0",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/router-cli": "1.167.17",
    "@types/node": "25.9.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "dotenv-cli": "11.0.0",
    "prisma": "7.8.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}